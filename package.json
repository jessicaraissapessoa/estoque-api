{
  "name": "estoque-api",
  "version": "1.0.0",
  "description": "API simples de registros de estoque com testes automatizados e pipeline de CI.",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "test": "mocha \"test/**/*.test.js\" --reporter mochawesome --reporter-options reportDir=mochawesome-report,reportFilename=index,html=true,json=true,overwrite=true,inlineAssets=true"
  },
  "keywords": [
    "estoque",
    "api",
    "express",
    "github-actions",
    "mocha"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "express": "^4.19.2"
  },
  "devDependencies": {
    "chai": "^4.5.0",
    "mocha": "^10.7.3",
    "mochawesome": "^7.1.3",
    "supertest": "^7.0.0"
  },
  "overrides": {
    "serialize-javascript": "^7.0.5",
    "uuid": "^11.1.1"
  }
}
